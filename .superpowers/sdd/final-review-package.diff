++        _ingest_from_zotero(ctx, zotero_key, no_graph)
++        return
++
+     # 批量模式
+     if batch:
+         _ingest_batch(ctx, batch, no_graph)
+         return
+ 
+     # 本地文件模式
+     if file_path is not None:
+         _ingest_local_pdf(ctx, file_path, no_graph)
+         return
+ 
