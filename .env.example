# PaperBase Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env to version control!

# ============================================
# LLM Configuration (Optional)
# ============================================
# PaperBase can work without LLM (external agents provide intelligence)
# Enable internal LLM only if you want automatic entity extraction during ingest

# Choose ONE of the following providers:

# --------------------------------------------
# Option 1: OpenAI (Recommended for production)
# --------------------------------------------
PAPERBASE_LLM_BASE_URL=https://api.openai.com/v1
PAPERBASE_LLM_API_KEY=sk-proj-your-openai-key-here
PAPERBASE_LLM_MODEL=gpt-4o-mini

# Cost estimate: ~$0.15 per 100 papers (gpt-4o-mini)
# Alternative models: gpt-4o (more accurate, ~$3 per 100 papers)

# --------------------------------------------
# Option 2: Anthropic Claude (via LiteLLM proxy)
# --------------------------------------------
# PAPERBASE_LLM_BASE_URL=http://localhost:8000/v1
# PAPERBASE_LLM_API_KEY=sk-ant-your-anthropic-key-here
# PAPERBASE_LLM_MODEL=claude-3-5-sonnet-20241022

# Setup: pip install litellm && litellm --model claude-3-5-sonnet-20241022

# --------------------------------------------
# Option 3: Ollama (Free local inference)
# --------------------------------------------
# PAPERBASE_LLM_BASE_URL=http://localhost:11434/v1
# PAPERBASE_LLM_API_KEY=not-required
# PAPERBASE_LLM_MODEL=llama3.2

# Setup:
#   1. Install Ollama: https://ollama.ai
#   2. Pull model: ollama pull llama3.2
#   3. Start server: ollama serve

# --------------------------------------------
# Option 4: Azure OpenAI
# --------------------------------------------
# PAPERBASE_LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-02-15-preview
# PAPERBASE_LLM_API_KEY=your-azure-api-key
# PAPERBASE_LLM_MODEL=gpt-4o

# --------------------------------------------
# Option 5: Chinese Providers (OpenAI-compatible)
# --------------------------------------------
# Alibaba Qwen (通义千问)
# PAPERBASE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# PAPERBASE_LLM_API_KEY=sk-your-dashscope-key
# PAPERBASE_LLM_MODEL=qwen-turbo

# Zhipu AI (智谱清言)
# PAPERBASE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# PAPERBASE_LLM_API_KEY=your-zhipu-key
# PAPERBASE_LLM_MODEL=glm-4

# ============================================
# Additional Configuration (Optional)
# ============================================

# --------------------------------------------
# Library Location
# --------------------------------------------
# 指定论文库存储目录（默认为项目根目录下的 ./library）
# 用途：
#   - 跨项目共享论文库
#   - 将论文存储在外部硬盘或网络存储
#   - 在不同环境中使用相同的论文数据
# 示例：
#   PAPERBASE_LIBRARY=/path/to/your/library
#   PAPERBASE_LIBRARY=~/Documents/Research/PaperLibrary
# 注意：路径必须存在且具有读写权限
# PAPERBASE_LIBRARY=/path/to/your/library

# --------------------------------------------
# Operation Timeout
# --------------------------------------------
# 设置长时运行命令的超时时间（单位：秒，默认 600 秒）
# 用途：
#   - 大型 PDF 转换可能需要更长时间
#   - 批量摄入多篇论文时避免超时
#   - 网络较慢时获取在线论文
# 示例：
#   PAPERBASE_TIMEOUT=1200  # 20 分钟
#   PAPERBASE_TIMEOUT=300   # 5 分钟（快速测试）
# 注意：设置过短可能导致操作未完成就被中断
# PAPERBASE_TIMEOUT=600

# ============================================
# Notes
# ============================================
# 1. After creating .env, enable LLM in config/paperbase.yaml:
#    llm:
#      enabled: true
#      auto_extract_on_ingest: true
#
# 2. Verify configuration:
#    uv run paperbase doctor
#
# 3. Test entity extraction:
#    uv run paperbase ingest arxiv:1706.03762
#
# 4. Security:
#    - .env is in .gitignore (never commit it!)
#    - For production, use system environment variables
#    - For Docker, use secrets or env_file
